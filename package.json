{
  "name": "@neststack/source",
  "version": "0.0.0",
  "private": true,
  "description": "NestStack Advanced Packages Monorepo",
  "license": "MIT",
  "author": "Mike Cojocari",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "build:config": "nx build config",
    "build:docs": "nx build docs && nx postbuild docs",
    "build:demo": "nx build demo",
    "test": "nx run-many -t test",
    "test:config": "nx test config",
    "test:coverage": "nx test config --coverage",
    "test:e2e": "nx e2e demo-e2e",
    "lint": "nx run-many -t lint",
    "format": "nx run-many -t format",
    "check": "nx run-many -t check",
    "lint:ci": "biome ci .",
    "typecheck": "nx run-many -t typecheck",
    "dev:docs": "nx dev docs",
    "dev:demo": "nx serve demo",
    "release": "nx release",
    "release:version": "nx release version",
    "release:changelog": "nx release changelog",
    "release:publish": "nx release publish",
    "graph": "nx graph",
    "clean": "nx reset"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "nx",
      "unrs-resolver",
      "@nestjs/core",
      "@swc/core",
      "@parcel/watcher",
      "sharp"
    ],
    "overrides": {
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "minimatch@>=7.0.0 <7.4.7": ">=7.4.7",
      "minimatch@>=7.0.0 <7.4.8": ">=7.4.8",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@nx/js": "22.6.1",
    "@nx/nest": "22.6.1",
    "@nx/node": "22.6.1",
    "@nx/vitest": "22.6.1",
    "@nx/web": "22.6.1",
    "@nx/webpack": "22.6.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.19",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "nx": "22.6.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "verdaccio": "^6.3.2",
    "vitest": "^4.1.1",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "axios": "^1.15.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "nx": {
    "includedScripts": []
  }
}
